---
import Hero from "@components/Hero.astro";
import Header from "../components/Header.astro";
import Layout from "../layouts/Layout.astro";
import { content } from "../data/content.ts";
import ContactButtons from "@components/ContactButtons.astro";
import Skills from "@components/Skills.astro";
import Experience from "@components/Experience.astro";
import Education from "@components/Education.astro";
const lang = "en";
const data = content[lang];
---

<Layout title="Pedro Edward Lumbre Cama - Mobile Software Engineer" lang="en">
  <Header lang={lang} />
  <main class="mx-auto max-w-7xl px-4 pb-16 sm:px-6 lg:px-8">
    <Hero content={data} />
    <ContactButtons content={data} />
    <Skills content={data} />
    <Experience content={data} />
    <Education content={data} />
    <div class="mt-16 border-t border-white/10 pt-8 text-center text-slate-400">
      <p class="text-sm">© 2026 droperdev. {data.rights}</p>
    </div>
  </main>
</Layout>
