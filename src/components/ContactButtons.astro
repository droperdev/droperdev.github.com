---
const { content } = Astro.props;
---

<div class="mb-16 grid gap-3 sm:grid-cols-2 lg:grid-cols-4" data-reveal>
  <a
    href={`mailto:${content.contact.email}`}
    class="flex min-h-14 min-w-0 items-center gap-3 rounded-2xl border border-cyan-400/30 bg-slate-950/70 px-4 py-3 text-sm font-medium text-cyan-50 transition duration-300 hover:-translate-y-0.5 hover:bg-cyan-400/10"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
      ></path>
    </svg>
    <span class="break-all">{content.contact.email}</span>
  </a>
  <a
    href={`tel:${content.contact.phone.replaceAll(" ", "")}`}
    class="flex min-h-14 items-center gap-3 rounded-2xl border border-emerald-400/30 bg-slate-950/70 px-4 py-3 text-sm font-medium text-emerald-50 transition duration-300 hover:-translate-y-0.5 hover:bg-emerald-400/10"
  >
    <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.95.684l1.2 3.6a1 1 0 01-.25 1.023l-1.7 1.7a15.93 15.93 0 006.51 6.51l1.7-1.7a1 1 0 011.023-.25l3.6 1.2a1 1 0 01.684.95V19a2 2 0 01-2 2h-1C10.163 21 3 13.837 3 5z"
      ></path>
    </svg>
    <span>{content.contact.phone}</span>
  </a>
  <a
    href={content.contact.linkedin}
    target="_blank"
    rel="noopener noreferrer"
    class="flex min-h-14 items-center gap-3 rounded-2xl border border-blue-400/30 bg-slate-950/70 px-4 py-3 text-sm font-medium text-blue-50 transition duration-300 hover:-translate-y-0.5 hover:bg-blue-400/10"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
      ></path>
    </svg>
    <span>LinkedIn</span>
  </a>
  <a
    href={content.contact.github}
    target="_blank"
    rel="noopener noreferrer"
    class="flex min-h-14 items-center gap-3 rounded-2xl border border-slate-400/30 bg-slate-950/70 px-4 py-3 text-sm font-medium text-slate-50 transition duration-300 hover:-translate-y-0.5 hover:bg-slate-400/10"
  >
    <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
      <path
        d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
      ></path>
    </svg>
    <span>GitHub</span>
  </a>
</div>
