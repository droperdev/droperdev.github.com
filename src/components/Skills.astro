---
import { skills } from "../data/content.ts";
const { content } = Astro.props;
---

<section class="mb-16" data-reveal>
  <h2 class="mb-8 flex items-center text-3xl font-bold text-white">
    <svg
      class="mr-3 h-8 w-8 text-cyan-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"
      ></path>
    </svg>
    {content.sections.skills}
  </h2>
  <div class="rounded-[1.5rem] border border-white/10 bg-slate-950/55 p-4 shadow-2xl shadow-black/20 md:p-6">
    <div class="grid gap-px overflow-hidden rounded-2xl bg-white/10 md:grid-cols-2 lg:grid-cols-3">
      {
        Object.values(skills).map((group: any) => (
          <div class="bg-slate-950/90 p-6 transition duration-300 hover:bg-slate-900">
            <p class="text-sm uppercase tracking-[0.18em] text-cyan-300">
              {group.title}
            </p>
            <p class="mt-5 text-lg font-semibold leading-7 text-white">
              {group.primary}
            </p>
            <p class="mt-3 text-sm leading-6 text-slate-400">
              {group.secondary}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
