---
const { content } = Astro.props;
---

<section class="relative overflow-hidden py-14 md:py-20">
  <div class="hero-panel" aria-hidden="true"></div>
  <div
    class="relative grid items-center gap-10 rounded-[1.75rem] border border-white/10 bg-slate-950/50 p-6 shadow-2xl shadow-black/20 backdrop-blur md:p-10 lg:grid-cols-[0.85fr_1.15fr]"
    data-reveal
  >
    <div class="flex justify-center lg:justify-start">
      <img
        src="https://github.com/droperdev.png"
        alt="Pedro Lumbre"
        class="profile-photo h-40 w-40 rounded-3xl border border-cyan-300/30 object-cover shadow-2xl shadow-cyan-500/10 md:h-56 md:w-56"
      />
    </div>
    <div class="text-center lg:text-left">
      <div class="mb-5 text-sm font-medium uppercase tracking-[0.22em] text-cyan-200">
        {content.location}
      </div>
      <h1 class="text-4xl font-bold tracking-normal text-white sm:text-5xl md:text-6xl">
        {content.name}
      </h1>
      <p class="mt-4 text-2xl font-semibold text-cyan-200 md:text-3xl">
        {content.title}
      </p>
      <p class="mt-6 max-w-3xl text-lg leading-relaxed text-slate-200">
        {content.tagline}
      </p>
      <p class="mt-5 max-w-3xl leading-relaxed text-slate-300">
        {content.about}
      </p>
      <div class="mt-8 grid gap-3 md:grid-cols-3">
        {
          content.focus.map((item: any) => (
            <div class="rounded-2xl border border-white/10 bg-slate-900/70 p-4 text-left">
              <p class="text-sm font-semibold text-white">{item.title}</p>
              <p class="mt-2 text-sm leading-6 text-slate-400">{item.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <div class="mt-5 grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {
      content.stats.map((stat: any) => (
        <div class="metric-card rounded-2xl border border-white/10 bg-slate-900/65 p-5" data-reveal>
          <p class="text-3xl font-bold text-white">{stat.value}</p>
          <p class="mt-2 text-sm text-slate-300">{stat.label}</p>
        </div>
      ))
    }
  </div>
</section>
