---
const { content } = Astro.props;
---

<section data-reveal>
  <h2 class="mb-8 flex items-center text-3xl font-bold text-white">
    <svg
      class="mr-3 h-8 w-8 text-cyan-300"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 14l9-5-9-5-9 5 9 5z"
      ></path>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 14l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14z"
      ></path>
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M12 14l9-5-9-5-9 5 9 5zm0 0l6.16-3.422a12.083 12.083 0 01.665 6.479A11.952 11.952 0 0012 20.055a11.952 11.952 0 00-6.824-2.998 12.078 12.078 0 01.665-6.479L12 14zm-4 6v-7.5l4-2.222"
      ></path>
    </svg>
    {content.sections.education}
  </h2>
  <div class="grid gap-4 md:grid-cols-2">
    {
      content.education.map((edu: any) => (
        <div class="rounded-2xl border border-white/10 bg-slate-950/70 p-6 shadow-xl shadow-black/10 backdrop-blur transition duration-300 hover:-translate-y-1 hover:border-cyan-300/30 hover:bg-slate-900/80">
          <h3 class="mb-2 text-xl font-bold text-white">{edu.degree}</h3>
          <p class="mb-2 text-cyan-200">{edu.institution}</p>
          <p class="text-sm text-slate-400">{edu.period}</p>
        </div>
      ))
    }
  </div>
</section>
